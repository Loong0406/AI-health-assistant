<?xml version="1.0" encoding="UTF-8"?>
<web-app>

    <display-name>智能健康助手</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 注册 Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- 登录 Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- 退出 Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- 健康档案 Servlet -->
    <servlet>
        <servlet-name>HealthProfileServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.HealthProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HealthProfileServlet</servlet-name>
        <url-pattern>/health-profile</url-pattern>
    </servlet-mapping>

    <!-- 生成计划 Servlet -->
    <servlet>
        <servlet-name>GeneratePlanServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.GeneratePlanServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GeneratePlanServlet</servlet-name>
        <url-pattern>/generate-plan</url-pattern>
    </servlet-mapping>

    <!-- 体重追踪 Servlet -->
    <servlet>
        <servlet-name>WeightTrackServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.WeightTrackServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WeightTrackServlet</servlet-name>
        <url-pattern>/weight-track</url-pattern>
    </servlet-mapping>

    <!-- 历史记录 Servlet -->
    <servlet>
        <servlet-name>HistoryServlet</servlet-name>
        <servlet-class>com.health.assistant.servlet.HistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HistoryServlet</servlet-name>
        <url-pattern>/history</url-pattern>
    </servlet-mapping>

</web-app>